\subsubsection{D.2 Installation}\label{d.2-installation}

\begin{Shaded}
\begin{Highlighting}[]
\CommentTok{\# Clone repository}
\FunctionTok{git}\NormalTok{ clone https://github.com/username/privacy{-}phenotype{-}matching.git}
\BuiltInTok{cd}\NormalTok{ privacy{-}phenotype{-}matching}

\CommentTok{\# Create virtual environment}
\ExtensionTok{python3} \AttributeTok{{-}m}\NormalTok{ venv venv}
\BuiltInTok{source}\NormalTok{ venv/bin/activate}

\CommentTok{\# Install dependencies}
\ExtensionTok{pip}\NormalTok{ install }\AttributeTok{{-}r}\NormalTok{ requirements.txt}

\CommentTok{\# Download HPO data}
\ExtensionTok{python} \AttributeTok{{-}c} \StringTok{"from src.data\_integration.external\_sources import download\_hpo\_data; download\_hpo\_data()"}
\end{Highlighting}
\end{Shaded}

\subsubsection{D.3 Core API Reference}\label{d.3-core-api-reference}

\paragraph{Similarity Module}\label{similarity-module}

\begin{Shaded}
\begin{Highlighting}[]
\ImportTok{from}\NormalTok{ src.similarity.hpo\_similarity }\ImportTok{import}\NormalTok{ (}
\NormalTok{    JaccardSimilarity,}
\NormalTok{    CosineSimilarity,}
\NormalTok{    ResnikSimilarity}
\NormalTok{)}

\CommentTok{\# Initialize with IC values}
\NormalTok{ic\_values }\OperatorTok{=}\NormalTok{ load\_ic\_values(}\StringTok{"data/hpo/ic\_values.json"}\NormalTok{)}
\NormalTok{resnik }\OperatorTok{=}\NormalTok{ ResnikSimilarity(ic\_values}\OperatorTok{=}\NormalTok{ic\_values)}

\CommentTok{\# Compute similarity between phenotype sets}
\NormalTok{patient1\_terms }\OperatorTok{=}\NormalTok{ [}\StringTok{"HP:0001250"}\NormalTok{, }\StringTok{"HP:0001263"}\NormalTok{, }\StringTok{"HP:0002376"}\NormalTok{]}
\NormalTok{patient2\_terms }\OperatorTok{=}\NormalTok{ [}\StringTok{"HP:0001250"}\NormalTok{, }\StringTok{"HP:0001344"}\NormalTok{, }\StringTok{"HP:0002540"}\NormalTok{]}

\NormalTok{similarity }\OperatorTok{=}\NormalTok{ resnik.compute\_pairwise\_similarity(patient1\_terms, patient2\_terms)}
\BuiltInTok{print}\NormalTok{(}\SpecialStringTok{f"Resnik similarity: }\SpecialCharTok{\{}\NormalTok{similarity}\SpecialCharTok{:.4f\}}\SpecialStringTok{"}\NormalTok{)}
\end{Highlighting}
\end{Shaded}

\paragraph{Privacy Module}\label{privacy-module}

\begin{Shaded}
\begin{Highlighting}[]
\ImportTok{from}\NormalTok{ src.privacy.psi }\ImportTok{import}\NormalTok{ DiffieHellmanPSI}
\ImportTok{from}\NormalTok{ src.privacy.differential\_privacy }\ImportTok{import}\NormalTok{ LaplaceMechanism}
\ImportTok{from}\NormalTok{ src.privacy.k\_anonymity }\ImportTok{import}\NormalTok{ KAnonymityFilter}

\CommentTok{\# Private Set Intersection}
\NormalTok{psi }\OperatorTok{=}\NormalTok{ DiffieHellmanPSI()}
\NormalTok{client\_set }\OperatorTok{=}\NormalTok{ \{}\StringTok{"HP:0001250"}\NormalTok{, }\StringTok{"HP:0001263"}\NormalTok{\}}
\NormalTok{server\_set }\OperatorTok{=}\NormalTok{ \{}\StringTok{"HP:0001250"}\NormalTok{, }\StringTok{"HP:0002376"}\NormalTok{, }\StringTok{"HP:0001344"}\NormalTok{\}}

\NormalTok{intersection }\OperatorTok{=}\NormalTok{ psi.compute\_intersection(client\_set, server\_set)}
\BuiltInTok{print}\NormalTok{(}\SpecialStringTok{f"Intersection: }\SpecialCharTok{\{}\NormalTok{intersection}\SpecialCharTok{\}}\SpecialStringTok{"}\NormalTok{)}

\CommentTok{\# Differential Privacy}
\NormalTok{dp }\OperatorTok{=}\NormalTok{ LaplaceMechanism(epsilon}\OperatorTok{=}\FloatTok{5.0}\NormalTok{)}
\NormalTok{private\_score }\OperatorTok{=}\NormalTok{ dp.privatize\_similarity(}\FloatTok{0.85}\NormalTok{)}
\BuiltInTok{print}\NormalTok{(}\SpecialStringTok{f"Privatized similarity: }\SpecialCharTok{\{}\NormalTok{private\_score}\SpecialCharTok{:.4f\}}\SpecialStringTok{"}\NormalTok{)}

\CommentTok{\# K{-}Anonymity}
\NormalTok{k\_anon }\OperatorTok{=}\NormalTok{ KAnonymityFilter(k}\OperatorTok{=}\DecValTok{5}\NormalTok{)}
\NormalTok{should\_suppress }\OperatorTok{=}\NormalTok{ k\_anon.check\_suppression(query\_phenotypes, database)}
\end{Highlighting}
\end{Shaded}

\paragraph{Evaluation Module}\label{evaluation-module}

\begin{Shaded}
\begin{Highlighting}[]
\ImportTok{from}\NormalTok{ src.evaluation.metrics }\ImportTok{import}\NormalTok{ RetrievalMetrics}

\NormalTok{metrics }\OperatorTok{=}\NormalTok{ RetrievalMetrics()}

\CommentTok{\# Compute retrieval performance}
\NormalTok{results }\OperatorTok{=}\NormalTok{ metrics.evaluate(}
\NormalTok{    similarities}\OperatorTok{=}\NormalTok{similarity\_matrix,}
\NormalTok{    ground\_truth}\OperatorTok{=}\NormalTok{disease\_labels,}
\NormalTok{    k\_values}\OperatorTok{=}\NormalTok{[}\DecValTok{1}\NormalTok{, }\DecValTok{5}\NormalTok{, }\DecValTok{10}\NormalTok{]}
\NormalTok{)}

\BuiltInTok{print}\NormalTok{(}\SpecialStringTok{f"nDCG@10: }\SpecialCharTok{\{}\NormalTok{results[}\StringTok{\textquotesingle{}ndcg\textquotesingle{}}\NormalTok{][}\DecValTok{10}\NormalTok{]}\SpecialCharTok{:.4f\}}\SpecialStringTok{"}\NormalTok{)}
\BuiltInTok{print}\NormalTok{(}\SpecialStringTok{f"MRR: }\SpecialCharTok{\{}\NormalTok{results[}\StringTok{\textquotesingle{}mrr\textquotesingle{}}\NormalTok{]}\SpecialCharTok{:.4f\}}\SpecialStringTok{"}\NormalTok{)}
\end{Highlighting}
\end{Shaded}

\subsubsection{D.4 Phenopacket Format}\label{d.4-phenopacket-format}

Our system uses GA4GH Phenopackets v2.0 for patient representation:

\begin{Shaded}
\begin{Highlighting}[]
\FunctionTok{\{}
  \DataTypeTok{"id"}\FunctionTok{:} \StringTok{"patient{-}001"}\FunctionTok{,}
  \DataTypeTok{"subject"}\FunctionTok{:} \FunctionTok{\{}
    \DataTypeTok{"id"}\FunctionTok{:} \StringTok{"patient{-}001"}\FunctionTok{,}
    \DataTypeTok{"timeAtLastEncounter"}\FunctionTok{:} \FunctionTok{\{}
      \DataTypeTok{"age"}\FunctionTok{:} \FunctionTok{\{}
        \DataTypeTok{"iso8601duration"}\FunctionTok{:} \StringTok{"P25Y"}
      \FunctionTok{\}}
    \FunctionTok{\},}
    \DataTypeTok{"sex"}\FunctionTok{:} \StringTok{"FEMALE"}
  \FunctionTok{\},}
  \DataTypeTok{"phenotypicFeatures"}\FunctionTok{:} \OtherTok{[}
    \FunctionTok{\{}
      \DataTypeTok{"type"}\FunctionTok{:} \FunctionTok{\{}
        \DataTypeTok{"id"}\FunctionTok{:} \StringTok{"HP:0001250"}\FunctionTok{,}
        \DataTypeTok{"label"}\FunctionTok{:} \StringTok{"Seizure"}
      \FunctionTok{\},}
      \DataTypeTok{"excluded"}\FunctionTok{:} \KeywordTok{false}\FunctionTok{,}
      \DataTypeTok{"onset"}\FunctionTok{:} \FunctionTok{\{}
        \DataTypeTok{"age"}\FunctionTok{:} \FunctionTok{\{}
          \DataTypeTok{"iso8601duration"}\FunctionTok{:} \StringTok{"P5Y"}
        \FunctionTok{\}}
      \FunctionTok{\}}
    \FunctionTok{\}}\OtherTok{,}
    \FunctionTok{\{}
      \DataTypeTok{"type"}\FunctionTok{:} \FunctionTok{\{}
        \DataTypeTok{"id"}\FunctionTok{:} \StringTok{"HP:0001263"}\FunctionTok{,}
        \DataTypeTok{"label"}\FunctionTok{:} \StringTok{"Global developmental delay"}
      \FunctionTok{\},}
      \DataTypeTok{"excluded"}\FunctionTok{:} \KeywordTok{false}
    \FunctionTok{\}}
  \OtherTok{]}\FunctionTok{,}
  \DataTypeTok{"diseases"}\FunctionTok{:} \OtherTok{[}
    \FunctionTok{\{}
      \DataTypeTok{"term"}\FunctionTok{:} \FunctionTok{\{}
        \DataTypeTok{"id"}\FunctionTok{:} \StringTok{"OMIM:312750"}\FunctionTok{,}
        \DataTypeTok{"label"}\FunctionTok{:} \StringTok{"Rett Syndrome"}
      \FunctionTok{\}}
    \FunctionTok{\}}
  \OtherTok{]}\FunctionTok{,}
  \DataTypeTok{"metaData"}\FunctionTok{:} \FunctionTok{\{}
    \DataTypeTok{"created"}\FunctionTok{:} \StringTok{"2026{-}04{-}20T12:00:00Z"}\FunctionTok{,}
    \DataTypeTok{"createdBy"}\FunctionTok{:} \StringTok{"privacy{-}phenotype{-}matching"}\FunctionTok{,}
    \DataTypeTok{"phenopacketSchemaVersion"}\FunctionTok{:} \StringTok{"2.0"}
  \FunctionTok{\}}
\FunctionTok{\}}
\end{Highlighting}
\end{Shaded}

\subsubsection{D.5 Configuration
Options}\label{d.5-configuration-options}

\begin{Shaded}
\begin{Highlighting}[]
\CommentTok{\# Privacy configuration}
\NormalTok{PRIVACY\_CONFIG }\OperatorTok{=}\NormalTok{ \{}
    \StringTok{"psi"}\NormalTok{: \{}
        \StringTok{"enabled"}\NormalTok{: }\VariableTok{True}\NormalTok{,}
        \StringTok{"curve"}\NormalTok{: }\StringTok{"SECP256R1"}\NormalTok{,}
        \StringTok{"security\_parameter"}\NormalTok{: }\DecValTok{128}
\NormalTok{    \},}
    \StringTok{"differential\_privacy"}\NormalTok{: \{}
        \StringTok{"enabled"}\NormalTok{: }\VariableTok{True}\NormalTok{,}
        \StringTok{"epsilon"}\NormalTok{: }\FloatTok{5.0}\NormalTok{,}
        \StringTok{"delta"}\NormalTok{: }\FloatTok{1e{-}5}\NormalTok{,}
        \StringTok{"mechanism"}\NormalTok{: }\StringTok{"laplace"}  \CommentTok{\# or "gaussian"}
\NormalTok{    \},}
    \StringTok{"k\_anonymity"}\NormalTok{: \{}
        \StringTok{"enabled"}\NormalTok{: }\VariableTok{True}\NormalTok{,}
        \StringTok{"k"}\NormalTok{: }\DecValTok{5}\NormalTok{,}
        \StringTok{"suppress\_on\_failure"}\NormalTok{: }\VariableTok{True}
\NormalTok{    \},}
    \StringTok{"rare\_term\_filtering"}\NormalTok{: \{}
        \StringTok{"enabled"}\NormalTok{: }\VariableTok{True}\NormalTok{,}
        \StringTok{"prevalence\_threshold"}\NormalTok{: }\FloatTok{0.01}\NormalTok{,}
        \StringTok{"generalize\_to\_parent"}\NormalTok{: }\VariableTok{True}
\NormalTok{    \}}
\NormalTok{\}}

\CommentTok{\# Similarity configuration}
\NormalTok{SIMILARITY\_CONFIG }\OperatorTok{=}\NormalTok{ \{}
    \StringTok{"metric"}\NormalTok{: }\StringTok{"resnik"}\NormalTok{,  }\CommentTok{\# "jaccard", "cosine", "resnik"}
    \StringTok{"ic\_source"}\NormalTok{: }\StringTok{"corpus"}\NormalTok{,  }\CommentTok{\# "corpus" or "intrinsic"}
    \StringTok{"aggregation"}\NormalTok{: }\StringTok{"bma"}  \CommentTok{\# "bma" or "max"}
\NormalTok{\}}
\end{Highlighting}
\end{Shaded}

\subsubsection{D.6 Running Evaluations}\label{d.6-running-evaluations}

\begin{Shaded}
\begin{Highlighting}[]
\CommentTok{\# Generate synthetic patients from HPOA}
\ExtensionTok{python} \AttributeTok{{-}m}\NormalTok{ src.data\_integration.hpoa\_patient\_generator }\DataTypeTok{\textbackslash{}}
    \AttributeTok{{-}{-}n\_patients}\NormalTok{ 500 }\DataTypeTok{\textbackslash{}}
    \AttributeTok{{-}{-}n\_diseases}\NormalTok{ 100 }\DataTypeTok{\textbackslash{}}
    \AttributeTok{{-}{-}output}\NormalTok{ data/synthetic\_patients.json}

\CommentTok{\# Run baseline evaluation}
\ExtensionTok{python} \AttributeTok{{-}m}\NormalTok{ src.evaluation.privacy\_utility }\DataTypeTok{\textbackslash{}}
    \AttributeTok{{-}{-}input}\NormalTok{ data/synthetic\_patients.json }\DataTypeTok{\textbackslash{}}
    \AttributeTok{{-}{-}output}\NormalTok{ results/evaluation\_results.json}

\CommentTok{\# Run privacy{-}utility tradeoff analysis}
\ExtensionTok{python} \AttributeTok{{-}m}\NormalTok{ src.evaluation.privacy\_utility }\DataTypeTok{\textbackslash{}}
    \AttributeTok{{-}{-}epsilon\_values}\NormalTok{ 0.1,0.5,1.0,2.0,5.0,10.0 }\DataTypeTok{\textbackslash{}}
    \AttributeTok{{-}{-}k\_values}\NormalTok{ 1,2,5,10,15,20 }\DataTypeTok{\textbackslash{}}
    \AttributeTok{{-}{-}output}\NormalTok{ results/privacy\_tradeoff.json}
\end{Highlighting}
\end{Shaded}

