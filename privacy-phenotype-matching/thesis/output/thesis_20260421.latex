\subsection{Appendix E: Glossary}\label{appendix-e-glossary}

{\def\LTcaptype{none} % do not increment counter
\begin{longtable}[]{@{}
  >{\raggedright\arraybackslash}p{(\linewidth - 2\tabcolsep) * \real{0.3333}}
  >{\raggedright\arraybackslash}p{(\linewidth - 2\tabcolsep) * \real{0.6667}}@{}}
\toprule\noalign{}
\begin{minipage}[b]{\linewidth}\raggedright
Term
\end{minipage} & \begin{minipage}[b]{\linewidth}\raggedright
Definition
\end{minipage} \\
\midrule\noalign{}
\endhead
\bottomrule\noalign{}
\endlastfoot
\textbf{BMA} & Best Match Average; aggregation strategy for semantic
similarity \\
\textbf{DDH} & Decisional Diffie-Hellman; cryptographic hardness
assumption \\
\textbf{DP} & Differential Privacy; formal privacy framework with
quantifiable guarantees \\
\textbf{HPO} & Human Phenotype Ontology; standardized vocabulary for
clinical phenotypes \\
\textbf{HPOA} & HPO Annotations; database linking diseases to phenotype
terms \\
\textbf{IC} & Information Content; measure of term specificity (-log
probability) \\
\textbf{k-anonymity} & Privacy model ensuring each record is
indistinguishable from k-1 others \\
\textbf{LSH} & Locality-Sensitive Hashing; approximate nearest neighbor
technique \\
\textbf{MICA} & Most Informative Common Ancestor; lowest common ancestor
with highest IC \\
\textbf{MME} & Matchmaker Exchange; federated network for rare disease
patient matching \\
\textbf{MRR} & Mean Reciprocal Rank; retrieval metric emphasizing first
relevant result \\
\textbf{nDCG} & Normalized Discounted Cumulative Gain; ranked retrieval
metric \\
\textbf{Phenopacket} & GA4GH standard format for patient phenotype data
exchange \\
\textbf{PSI} & Private Set Intersection; cryptographic protocol for set
comparison \\
\textbf{Resnik} & IC-based semantic similarity using most informative
common ancestor \\
\textbf{Sensitivity} & Maximum change in query output from
adding/removing one record \\
\end{longtable}
}

\begin{center}\rule{0.5\linewidth}{0.5pt}\end{center}

